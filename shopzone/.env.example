# Shopzone Environment Variables for Render/Production
# Copy to .env and fill values. Add to Render Dashboard.

SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.onrender.com,*.onrender.com
DATABASE_URL=postgres://... (auto-set by Render)

# Razorpay (get from dashboard)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_SECRET_KEY=...

# Email (optional)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
